#theme = TokyoNight 
theme = Rose Pine Moon

#font-family = "FiraMono Nerd Font"
#font-family = "JetBrainsMono Nerd Font"
font-family = "MonoLisaCode Trial"
font-size = 19

macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden
#macos-option-as-alt = left

copy-on-select = clipboard
confirm-close-surface = false
window-save-state = always
clipboard-paste-protection = false

shell-integration-features = no-title

# Split pane visibility
window-padding-x = 7
window-padding-y = 7
window-padding-balance = true
unfocused-split-opacity = 0.6
unfocused-split-fill = #393552

# Multiline input for Herdr/pi/Claude-style prompts
keybind = shift+enter=text:\n
keybind = alt+t=text:\x1bt

# Herdr zen macro: zoom current pane, then toggle sidebar.
keybind = ctrl+alt+super+shift+enter=text:\x02z\x02b

# Clear the visible screen (send Ctrl+L, including inside Zellij)
keybind = cmd+k=text:\x0c

# Line-by-line scrolling
keybind = cmd+up=scroll_page_lines:-1
keybind = cmd+down=scroll_page_lines:1

# Quake-style drop-down terminal
keybind = global:cmd+shift+k=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-autohide = true
