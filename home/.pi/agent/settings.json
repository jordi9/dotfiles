        "+extensions/amp-assistant-markdown.ts"
      ]
    },
    {
      "source": "git:github.com/championswimmer/pi-context-usage",
      "skills": []
    },
    "pnpm:pi-tool-stats",
    "pnpm:@firstpick/pi-extension-stats",
    "pnpm:@tintinweb/pi-subagents",
    "pnpm:@sinamtz/pi-minimax-provider",
    {
      "source": "git:github.com/DietrichGebert/ponytail",
      "extensions": [
        "-pi-extension/index.js"
      ],
      "skills": [
        "-skills/ponytail/SKILL.md",
        "-skills/ponytail-audit/SKILL.md",
        "-skills/ponytail-debt/SKILL.md",
        "-skills/ponytail-gain/SKILL.md",
        "-skills/ponytail-help/SKILL.md",
        "-skills/ponytail-review/SKILL.md"
      ]
    },
    {
      "source": "pnpm:pi-impeccable",
      "extensions": [
        "-extensions/impeccable.ts"
      ]
    },
    "~/dev/pi-impeccable",
    "pnpm:@ff-labs/pi-fff",
    "pnpm:pi-playwright",
    {
      "source": "pnpm:pi-ghostty-notifier",
      "extensions": [
        "-extensions/index.ts"
      ]
    },
    {
      "source": "../../dev/chloe",
      "extensions": [
        "+src/extension.ts"
      ]
    },
    "npm:@ogulcancelik/pi-herdr",
    "../../dev/pi-workspace",
    "npm:@juicesharp/rpiv-ask-user-question",
    "../../dev/pi-now",
    "npm:pi-playwright",
    "npm:@gotgenes/pi-subagents"
  ],
  "hideThinkingBlock": true,
  "terminal": {
    "showTerminalProgress": false
  }
